@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/index.css" asp-append-version="true" />
}

<div class="page-header">
    <h1>AI Gateway Infrastructure</h1>
    <p>Real-time monitoring of hardware resources and model inference pool</p>
</div>

<div class="metrics-grid">

    <div class="metric-card">
        <div class="card-header">
            <h3>VRAM Usage</h3>
            <i class="bi bi-memory text-indigo"></i>
        </div>
        <div class="card-body">
            <div class="metric-value font-mono" id="vram-val">0/0 GB</div>
            <div class="progress-bar-container">
                <div id="vram-progress" class="progress-bar bg-indigo" style="width: 0%"></div>
            </div>
        </div>
    </div>

    <div class="metric-card">
        <div class="card-header">
            <h3>GPU Load</h3>
            <i class="bi bi-speedometer text-emerald"></i>
        </div>
        <div class="card-body">
            <div class="metric-value font-mono" id="gpu-load-val">0%</div>
            <div class="progress-bar-container">
                <div id="gpu-load-progress" class="progress-bar bg-emerald" style="width: 0%"></div>
            </div>
        </div>
    </div>

    <div class="metric-card">
        <div class="card-header">
            <h3>GPU Temp</h3>
            <i class="bi bi-thermometer-half text-orange"></i>
        </div>
        <div class="card-body pb-1">
            <div class="metric-value font-mono" id="temp-val">0 °C</div>
            <div id="temp-status" class="status-text text-emerald">Normal</div>
        </div>
    </div>

    <div class="metric-card">
        <div class="card-header">
            <h3>System RAM</h3>
            <i class="bi bi-hdd-rack text-blue"></i>
        </div>
        <div class="card-body">
            <div class="metric-value font-mono" id="ram-val">0/0 GB</div>
            <div class="progress-bar-container">
                <div id="ram-progress" class="progress-bar bg-blue" style="width: 0%"></div>
            </div>
        </div>
    </div>

    <div class="metric-card">
        <div class="card-header">
            <h3>CPU Load</h3>
            <i class="bi bi-cpu text-cyan"></i>
        </div>
        <div class="card-body">
            <div class="metric-value font-mono" id="cpu-load-val">0%</div>
            <div class="progress-bar-container">
                <div id="cpu-load-progress" class="progress-bar bg-cyan" style="width: 0%"></div>
            </div>
        </div>
    </div>

    <div class="metric-card">
        <div class="card-header">
            <h3>Active Slots</h3>
            <i class="bi bi-diagram-3 text-purple"></i>
        </div>
        <div class="card-body pb-1">
            <div class="metric-value font-mono">
                <span id="active-slots-val">0</span><span class="sub-text"> active</span>
            </div>
            <div class="helper-text">
                Across <span id="models-count" class="font-bold">0</span> loaded targets
            </div>
        </div>
    </div>
</div>

<div class="table-section">
    <div class="table-header">
        <h2>Model Inference Pool</h2>
        <span class="update-note">Updated every 1.5s</span>
    </div>
    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Model ID</th>
                    <th>Status</th>
                    <th>Contexts / Slots Usage</th>
                    <th class="text-center">Queue</th>
                    <th>Runtime Configuration</th>
                </tr>
            </thead>
            <tbody id="models-body">
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/index.js" asp-append-version="true"></script>
}
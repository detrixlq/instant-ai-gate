@model AIModelsModel

<div id="config-drawer" class="drawer-container">
    <form id="drawer-form" asp-page-handler="Load" method="post" class="drawer-form-layout">
        <input type="hidden" id="drawer-input-modelpath" asp-for="SelectedSettings.RepoId" />

        <div id="drawer-loading-overlay" class="drawer-loading hidden opacity-0">
            <div class="spinner-loader"></div>
            <h3 class="loader-title">Activating Model Instance</h3>
            <p class="loader-description">Allocating layers to VRAM and generating context graphs. This may take up to a minute.</p>
        </div>

        <div class="drawer-header">
            <div>
                <h2>Deployment Parameters</h2>
                <p id="drawer-model-display-name" class="drawer-subtitle font-mono">Model Name</p>
            </div>
            <button id="drawer-close-btn" type="button" class="drawer-close-icon-btn" aria-label="Close configuration">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="drawer-body custom-scrollbar">

            <div class="accordion-item">
                <button type="button" class="accordion-trigger" data-target="topology-content" data-chevron="topology-chevron">
                    <span><i class="bi bi-cpu accordion-icon-prefix"></i> Compute Topology</span>
                    <i id="topology-chevron" class="bi bi-chevron-up accordion-chevron"></i>
                </button>

                <div id="topology-content" class="accordion-content">
                    <div class="input-group-spacing">
                        <div class="range-labels-wrapper">
                            <span class="label-with-tooltip">
                                GPU Layers Allocation
                                <i class="bi bi-question-circle tooltip-trigger" title="Number of LLM structural layers shifted directly onto VRAM. Setting to -1 targets automated, aggressive VRAM packing based on available hardware capacity."></i>
                            </span>
                            <span id="gpu-layers-val" class="range-live-value font-mono">20</span>
                        </div>
                        <input type="range" id="gpu-layers" asp-for="SelectedSettings.GpuLayerCount" min="-1" max="128" step="1" value="20" class="custom-range-slider">
                    </div>

                    <div class="grid-two-columns">
                        <div class="input-group-spacing">
                            <label class="label-with-tooltip">
                                CPU Threads
                                <i class="bi bi-question-circle tooltip-trigger" title="Number of CPU worker threads allocated for tensor mathematics. For optimal execution speed, set this equal to the number of physical CPU cores (avoid hyperthreading cores)."></i>
                            </label>
                            <input type="number" asp-for="SelectedSettings.Threads" min="1" max="64" class="custom-form-input font-mono">
                        </div>

                        <div class="input-group-spacing">
                            <label class="label-with-tooltip">
                                Primary GPU Index
                                <i class="bi bi-question-circle tooltip-trigger" title="The hardware identifier (ID) of the primary graphics card utilized to host the core compute context. Essential for multi-GPU arrays (0, 1, 2...)."></i>
                            </label>
                            <input type="number" asp-for="SelectedSettings.MainGpu" min="0" max="8" class="custom-form-input font-mono">
                        </div>
                    </div>

                    <div class="toggle-card-wrapper">
                        <span class="label-with-tooltip font-semibold uppercase-text">
                            CPU Only Mode
                            <i class="bi bi-question-circle tooltip-trigger" title="Forcefully bypasses GPU acceleration. The neural network pipeline will run exclusively on the host processor and standard system RAM."></i>
                        </span>
                        <label class="apple-switch">
                            <input type="checkbox" id="cpu-only-toggle">
                            <span class="slider"></span>
                        </label>
                    </div>
                </div>
            </div>

            <div class="accordion-item">
                <button type="button" class="accordion-trigger" data-target="memory-content" data-chevron="memory-chevron">
                    <span><i class="bi bi-brain accordion-icon-prefix"></i> Context & Context Window</span>
                    <i id="memory-chevron" class="bi bi-chevron-up accordion-chevron"></i>
                </button>

                <div id="memory-content" class="accordion-content">
                    <div class="input-group-spacing">
                        <label class="label-with-tooltip">
                            Context Size (Tokens)
                            <i class="bi bi-question-circle tooltip-trigger" title="The maximum boundary for the model's memory buffer. Expanding this allows for larger prompt strings and longer responses, but heavily amplifies VRAM allocation requirements for the KV-cache."></i>
                        </label>
                        <select asp-for="SelectedSettings.ContextSize" class="custom-form-select font-mono">
                            <optgroup label="Small / BERT">
                                <option value="512">512 Tokens (Minimal)</option>
                                <option value="1024">1024 Tokens (Basic)</option>
                            </optgroup>
                            <optgroup label="Standard">
                                <option value="2048">2048 Tokens (Base)</option>
                                <option value="4096" selected>4096 Tokens (Standard)</option>
                                <option value="8192">8192 Tokens (Extended)</option>
                            </optgroup>
                            <optgroup label="Deep-Context">
                                <option value="16384">16384 Tokens (High-Capacity)</option>
                                <option value="32768">32768 Tokens (Ultra-Capacity)</option>
                            </optgroup>
                        </select>
                    </div>

                    <div class="input-group-spacing">
                        <label class="label-with-tooltip">
                            Max Parallel Users
                            <i class="bi bi-question-circle tooltip-trigger" title="Configures the number of concurrency slots available before the backpressure semaphore engages. When limits are exceeded, extra concurrent requests will safely queue in an async buffer."></i>
                        </label>
                        <input type="number" asp-for="SelectedSettings.MaxContexts" min="1" max="32" value="2" class="custom-form-input font-mono">
                    </div>

                    <div class="checkbox-group-wrapper">
                        <label class="checkbox-custom-label">
                            <input type="checkbox" asp-for="SelectedSettings.FlashAttention" class="custom-checkbox-input">
                            <div>
                                <div class="checkbox-title">Enable Flash Attention</div>
                                <p class="checkbox-description">Mathematical optimization for attention matrix. Cuts VRAM utilization and accelerates long-context generations.</p>
                            </div>
                        </label>

                        <label class="checkbox-custom-label">
                            <input type="checkbox" asp-for="SelectedSettings.Embeddings" class="custom-checkbox-input">
                            <div>
                                <div class="checkbox-title">Expose Embeddings Endpoint</div>
                                <p class="checkbox-description">Activates semantic vector extraction layer. Toggle on only for vector-based RAG workflows.</p>
                            </div>
                        </label>
                    </div>
                </div>
            </div>

            <div class="accordion-item">
                <button type="button" class="accordion-trigger" data-target="performance-content" data-chevron="performance-chevron">
                    <span><i class="bi bi-sliders accordion-icon-prefix"></i> Performance Tuning</span>
                    <i id="performance-chevron" class="bi bi-chevron-down accordion-chevron"></i>
                </button>

                <div id="performance-content" class="accordion-content hidden">
                    <div class="input-group-spacing">
                        <label class="label-with-tooltip">
                            KV-Cache Compression
                            <i class="bi bi-question-circle tooltip-trigger" title="Quantizes the dynamic memory used for tracking chat history. Q5_0/Q8_0 preserves precise token attention links while saving up to 60% of VRAM on extended context windows."></i>
                        </label>
                        <select asp-for="SelectedSettings.KvCacheQuantization" class="custom-form-select font-mono">
                            <option value="F16" selected>Disabled (High Precision F16)</option>
                            <option value="Q8_K">High Fidelity (Q8_K Cache - Safe for all models)</option>
                            <option value="Q5_K">Symmetric Sweet Spot (Q5_K Cache - Best for Q5/Q6 weights)</option>
                            <option value="Q4_K">Maximum Compression (Q4_K Cache - Tight VRAM headroom)</option>
                        </select>
                    </div>

                    <div class="input-group-spacing">
                        <label class="label-with-tooltip">
                            Processing Batch Size
                            <i class="bi bi-question-circle tooltip-trigger" title="The chunk size of tokens processed simultaneously during large prompt ingestions. Lower values like 256 are highly recommended for CPU Only mode to prevent RAM cache thrashing."></i>
                        </label>
                        <select asp-for="SelectedSettings.BatchSize" class="custom-form-select font-mono">
                            <option value="256">256 Tokens (Optimized for CPU Only)</option>
                            <option value="512" selected>512 Tokens (Standard / Hybrid Default)</option>
                            <option value="1024">1024 Tokens (Performance GPU)</option>
                            <option value="2048">2048 Tokens (Enterprise / Server GPU)</option>
                        </select>
                    </div>

                    <div class="checkbox-group-wrapper">
                        <label class="checkbox-custom-label">
                            <input type="checkbox" asp-for="SelectedSettings.UseMemoryLock" class="custom-checkbox-input">
                            <div>
                                <div class="checkbox-title">Lock Model in Physical Memory (mlock)</div>
                                <p class="checkbox-description">Forces the OS to lock the model weights inside physical RAM/VRAM. Prevents the deployment from being paged out into disk Swap, eliminating system lag spikes after periods of inactivity.</p>
                            </div>
                        </label>
                    </div>
                </div>
            </div>
        </div>

        <div class="drawer-footer">
            <button id="drawer-cancel-btn" type="button" class="btn-drawer-dismiss">
                Cancel
            </button>
            <button id="drawer-submit-btn" type="submit" class="btn-drawer-action">
                <i id="submit-icon" class="bi bi-play-circle-fill"></i> Initialize Pipeline
            </button>
        </div>
    </form>
</div>

<div id="drawer-overlay" class="fixed-backdrop hidden opacity-0"></div>
@* Pages/Shared/_Layout.cshtml *@
<!DOCTYPE html>
<html lang="en" class="custom-scrollbar">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InstantAIGate</title>
    <link rel="icon" type="image/png" href="~/media/favicon.png">

    <link rel="stylesheet" href="~/lib/bootstrap-icons/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/global.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />

    @{
        var apiUrl = "";
        if (Model != null)
        {
            var prop = Model.GetType().GetProperty("APIUrl");
            if (prop != null)
            {
                apiUrl = prop.GetValue(Model)?.ToString() ?? "";
            }
        }
    }
    <meta name="app-api-url" content="@apiUrl" />
   
    <script>
            (function () {
                var stored = localStorage.getItem('theme');
                if (stored === 'dark' || (!stored && window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                    document.documentElement.classList.add('dark');
                } else {
                    document.documentElement.classList.remove('dark');
                }
            })();
    </script>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <header class="main-header">
        <div class="header-left">
            <button id="mobile-menu-toggle" type="button" class="btn-icon" title="Toggle menu">
                <i id="mobile-menu-icon" class="bi bi-list" style="font-size: 1.25rem;"></i>
            </button>

            <img alt="instantaigate-logo-small" src="~/media/ig-logo-small.png" style="height: 24px" />
            <span class="logo-text">
                InstantAI<span class="text-primary">Gate</span>
            </span>
        </div>

        <div class="header-right">
            <div id="global-signalr-badge" class="signalr-badge connecting">
                <span class="badge-dot animate-pulse"></span>
                <span class="hidden-sm">Connecting...</span>
                <span class="sm-hidden">...</span>
            </div>

            <button id="theme-toggle" type="button" class="btn-icon" title="Toggle theme">
                <i id="theme-toggle-icon" class="bi bi-moon" style="font-size: 1.25rem;"></i>
            </button>
        </div>
    </header>

    <div class="layout-wrapper">

        <div id="sidebar-backdrop" class="sidebar-backdrop hidden"></div>

        <aside id="sidebar-menu" class="sidebar">
            <nav class="sidebar-nav">

                <div class="nav-group">
                    <div class="nav-group-title">Monitoring</div>
                    <div class="nav-links-stack">
                        <a href="/" class="nav-link">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                    </div>
                </div>

                <div class="nav-group">
                    <div class="nav-group-title">Model Catalog</div>
                    <div class="nav-links-stack">
                        <a href="/AIModels" class="nav-link" data-path="/AIModels">
                            <i class="bi bi-cpu"></i> AI Models
                        </a>
                    </div>
                </div>

                <div class="nav-group">
                    <div class="nav-group-title">Laboratory</div>
                    <div class="nav-links-stack">
                        <a href="/LLMConsole" class="nav-link" data-path="/LLMConsole">
                            <i class="bi bi-terminal"></i> LLM Console
                        </a>
                        <a href="/EmbeddingLab" class="nav-link" data-path="/EmbeddingLab">
                            <i class="bi bi-cone-striped"></i> Embedding Lab
                        </a>
                    </div>
                </div>
            </nav>

            <div class="sidebar-footer">
                <div style="display: flex; align-items: center; gap: 0.375rem;">
                    <i class="bi bi-git"></i>
                    <span>Version</span>
                </div>
                <span class="version-tag">
                    @typeof(Program).Assembly.GetName().Version?.ToString(3)
                </span>
            </div>
        </aside>

        <main class="main-content">
            <div class="content-container">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/lib/microsoft-signalr/signalr.min.js"></script>
    <script src="~/js/layout.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
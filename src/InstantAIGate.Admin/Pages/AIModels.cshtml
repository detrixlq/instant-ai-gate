@page "{handler?}"
@model AIModelsModel
@using InstantAIGate.Domain.Enums;
@{
    ViewData["Title"] = "AI Models";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/aimodels.css" asp-append-version="true" />
}

<div class="page-header">
    <div>
        <h1>LLM Model Management</h1>
        <p>Download, deploy, and configure high-performance llama.cpp orchestration parameters.</p>
    </div>
</div>

@if (!ModelState.IsValid)
{
    <div class="validation-summary-alert">
        <div asp-validation-summary="All" class="font-medium"></div>
    </div>
}

<div class="table-section">
    <table class="data-table">
        <thead>
            <tr>
                <th class="pl-6">Model Name / Repository</th>
                <th>Model Type</th>
                <th>Weight Size</th>
                <th>Memory Status</th>
                <th class="pr-6 text-right">Actions</th>
            </tr>
        </thead>
        <tbody class="divide-y">
            @foreach (var item in Model.Models)
            {
                var isActive = Model.ActiveModelRepoIds.Contains(item.RepoId);
                var safeId = item.RepoId.Replace("/", "-").Replace(".", "-");

                <tr>
                    <td class="pl-6">
                        <div class="model-title">@item.DisplayName</div>
                        <div class="model-repo font-mono">@item.RepoId</div>
                    </td>


                    <td>
                        @if (item.ModelType == ModelType.Llm)
                        {
                            <span class="badge-status info font-mono text-xs">LLM</span>
                        }
                        else if (item.ModelType == ModelType.Bert)
                        {
                            <span class="badge-status warning font-mono text-xs">BERT</span>
                        }
                    </td>

                    <td class="font-mono text-xs text-muted-hover">
                        @((item.SizeBytes / 1024.0 / 1024.0 / 1024.0).ToString("0.00")) GB
                    </td>

                    <td id="status-cell-@safeId">
                        @if (isActive)
                        {
                            <span class="badge-status success">Active in VRAM</span>
                        }
                        else if (item.IsDownloaded)
                        {
                            <span class="badge-status info">Ready for Allocation</span>
                        }
                        else if (item.IsDownloading)
                        {
                            <div class="downloading-status-container">
                                <span class="badge-status warning">
                                    <i class="bi bi-arrow-repeat animate-spin"></i> Downloading @item.DownloadProgress.ToString("F1")%
                                </span>
                            </div>
                        }
                        else
                        {
                            <span class="badge-status default">Remote Instance</span>
                        }
                    </td>

                    <td class="pr-6 text-right">
                        <div class="actions-wrapper" id="actions-cell-@safeId">
                            @if (isActive)
                            {
                                <form asp-page-handler="Unload" asp-route-repoId="@item.RepoId" method="post" class="inline-form" onsubmit="showUnloadLoading(this)">
                                    <button type="submit" class="unload-btn btn-danger-secondary">
                                        <i class="bi bi-eject animate-icon"></i>
                                        <span class="btn-text">Unload</span>
                                    </button>
                                </form>

                                @if (item.ModelType == ModelType.Llm)
                                {
                                    <a href="/LLMConsole?repoId=@item.RepoId" class="console-link btn-primary">
                                        <i class="bi bi-terminal"></i> Console
                                    </a>
                                }
                                else if (item.ModelType == ModelType.Bert)
                                {
                                    <a href="/EmbeddingLab?repoId=@item.RepoId" class="embedding-lab-link btn-primary">
                                        <i class="bi bi-bezier2"></i> Embed Lab
                                    </a>
                                }
                            }
                            else if (item.IsDownloaded)
                            {
                                <button onclick="openConfigDrawer('@item.RepoId', '@item.DisplayName')" class="btn-secondary">
                                    <i class="bi bi-power"></i> Configure & Load
                                </button>
                            }
                            else if (item.IsDownloading)
                            {
                                <form asp-page-handler="CancelDownload" asp-route-repoId="@item.RepoId" method="post" class="inline-form cancel-download-form">
                                    <button type="submit" class="btn-danger-secondary">
                                        <i class="bi bi-slash-circle"></i> Cancel
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-page-handler="StartDownload" asp-route-repoId="@item.RepoId" method="post" class="inline-form">
                                    <button type="submit" class="btn-outline-primary">
                                        <i class="bi bi-cloud-download"></i> Download
                                    </button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }

            @if (!Model.Models.Any())
            {
                <tr>
                    <td colspan="5" class="table-empty-state">
                        No pipeline models discovered in local layout directory.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<partial name="./AIModels/_ConfigDrawer" model="Model" />

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        window.PageConfig = {
            apiUrl: "@Model.APIUrl"
        };
    </script>
    <script src="~/js/pages/aimodels.js" asp-append-version="true"></script>
    <script src="~/js/pages/aimodels-config.js" asp-append-version="true"></script>
}